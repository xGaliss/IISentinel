@inherits LayoutComponentBase
@rendermode InteractiveServer
<div class="app-shell">
    <aside class="sidebar">
        <div class="brand">
            <div class="brand-mark">II</div>
            <div>
                <div class="brand-title">IISEntinel</div>
                <div class="brand-subtitle">Central</div>
            </div>
        </div>

        <NavMenu />
    </aside>

    <div class="app-main">
        <header class="topbar">
            <div>
                <div class="topbar-title">Operations Console</div>
                <div class="topbar-subtitle">Monitor agents, IIS health and remote actions.</div>
            </div>

            <div class="topbar-right">
                <span class="topbar-pill">Preview</span>
            </div>
        </header>

        <main class="content">
            @Body
        </main>
    </div>
</div>