@page "/logs"
@rendermode InteractiveServer
@using IISentinel.Panel.Models
@inject IHttpClientFactory HttpClientFactory
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Logs</PageTitle>

<div class="logs-page">

    <!-- TOP BAR -->
    <div class="logs-toolbar">

        <button class="btn-iis btn-iis-start" @onclick="LoadLogsAsync">
            Refresh
        </button>

        <button class="btn-iis btn-iis-stop" @onclick="ToggleAutoRefresh">
            @(AutoRefreshEnabled ? "Auto ON" : "Auto OFF")
        </button>

        <select class="dark-select" @bind="SelectedLineCount">
            <option value="50">50</option>
            <option value="100">100</option>
            <option value="300">300</option>
            <option value="1000">1000</option>
        </select>

        <select class="dark-select" @bind="SelectedFile">
            @foreach (var file in AvailableFiles)
            {
                <option value="@file">@file</option>
            }
        </select>

        <button class="btn-iis" @onclick="DownloadCurrentLog">
            Download
        </button>

        <input class="dark-input"
               placeholder="Filter..."
               @bind="FilterText"
               @bind:event="oninput" />

    </div>

    <!-- LOG CONSOLE -->
    <div class="logs-console" id="logsConsole">
        @foreach (var line in FilteredLogLines)
        {
            <div class="@GetLogCssClass(line)">
                @line
            </div>
        }
    </div>

</div>

@code {
    private List<string> LogLines = new();
    private List<string> AvailableFiles = new();
    private bool _pendingScroll;

    private string? SelectedFile;
    private string FilterText = "";

    private int SelectedLineCount = 100;

    private bool AutoRefreshEnabled;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;

    private List<string> FilteredLogLines =>
        string.IsNullOrWhiteSpace(FilterText)
            ? LogLines
            : LogLines.Where(l => l.Contains(FilterText, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadLogsAsync();
    }

    private async Task LoadLogsAsync()
    {
        var client = HttpClientFactory.CreateClient("Agent");

        var url = $"/logs/recent?lines={SelectedLineCount}";
        if (!string.IsNullOrWhiteSpace(SelectedFile))
            url += $"&file={Uri.EscapeDataString(SelectedFile)}";

        var result = await client.GetFromJsonAsync<LogsResponseDto>(url);

        LogLines = result?.Lines ?? new();
        AvailableFiles = result?.Files ?? new();

        if (string.IsNullOrWhiteSpace(SelectedFile))
            SelectedFile = result?.File;

        // 👇 Espera a renderizar
        await InvokeAsync(StateHasChanged);

        // 👇 control de scroll
        _pendingScroll = true;
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingScroll)
        {
            _pendingScroll = false;
            await JS.InvokeVoidAsync("logsAutoScroll");
        }
    }

    private async Task ToggleAutoRefresh()
    {
        if (AutoRefreshEnabled)
        {
            AutoRefreshEnabled = false;
            _cts?.Cancel();
            return;
        }

        AutoRefreshEnabled = true;
        _cts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(5));

        try
        {
            while (await _timer.WaitForNextTickAsync(_cts.Token))
            {
                await LoadLogsAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { }
    }

    private void DownloadCurrentLog()
    {
        var baseUrl = Configuration["Agent:BaseUrl"]?.TrimEnd('/');
        var url = $"{baseUrl}/logs/download?file={Uri.EscapeDataString(SelectedFile ?? "")}";
        Navigation.NavigateTo(url, true);
    }

    private static string GetLogCssClass(string line)
    {
        if (line.Contains("[ERR]")) return "log-line log-error";
        if (line.Contains("[WRN]")) return "log-line log-warning";
        return "log-line log-info";
    }
}