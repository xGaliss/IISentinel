@page "/apppools"
@rendermode InteractiveServer
@using IISentinel.Panel.Models
@inject IHttpClientFactory HttpClientFactory

<PageTitle>App Pools</PageTitle>

<div class="page-shell">
    <div class="page-hero">
        <div>
            <div class="page-kicker">Monitoring</div>
            <h1 class="page-title">App Pools</h1>
            <div class="page-subtitle">Supervisa el estado y ejecuta acciones rápidas sobre los application pools.</div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }

    <div class="surface-card">
        <div class="toolbar-row">
            <button class="btn btn-primary" @onclick="LoadAppPoolsAsync" disabled="@IsLoading">
                @(IsLoading ? "Loading..." : "Refresh")
            </button>
        </div>

        @if (Pools.Count == 0 && !IsLoading && string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="empty-state">No app pools found.</div>
        }
        else if (Pools.Count > 0)
        {
            <div class="iis-table-wrap">
                <table class="iis-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>State</th>
                            <th style="width:320px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pool in Pools)
                        {
                            <tr>
                                <td>
                                    <div class="item-title">@pool.Name</div>
                                    <div class="item-meta">IIS application pool</div>
                                </td>
                                <td>
                                    <span class="@GetStateCss(pool.State)">@pool.State</span>
                                </td>
                                <td>
                                    <div class="action-group">
                                        <button class="btn-iis btn-iis-start"
                                                @onclick="() => StartPoolAsync(pool.Name)">
                                            Start
                                        </button>

                                        <button class="btn-iis btn-iis-stop"
                                                @onclick="() => StopPoolAsync(pool.Name)">
                                            Stop
                                        </button>

                                        <button class="btn-iis btn-iis-recycle"
                                                @onclick="() => RecyclePoolAsync(pool.Name)">
                                            Recycle
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<AppPoolDto> Pools { get; set; } = new();
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAppPoolsAsync();
    }

    private async Task LoadAppPoolsAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;

            var client = HttpClientFactory.CreateClient("Agent");
            var result = await client.GetFromJsonAsync<List<AppPoolDto>>("/apppools");

            Pools = result ?? new List<AppPoolDto>();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading app pools: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task StartPoolAsync(string name)
    {
        await PostActionAsync($"/apppools/{Uri.EscapeDataString(name)}/start");
    }

    private async Task StopPoolAsync(string name)
    {
        await PostActionAsync($"/apppools/{Uri.EscapeDataString(name)}/stop");
    }

    private async Task RecyclePoolAsync(string name)
    {
        await PostActionAsync($"/apppools/{Uri.EscapeDataString(name)}/recycle");
    }

    private async Task PostActionAsync(string url)
    {
        try
        {
            ErrorMessage = null;

            var client = HttpClientFactory.CreateClient("Agent");
            var response = await client.PostAsync(url, content: null);

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                ErrorMessage = $"Action failed: {(int)response.StatusCode} - {body}";
                return;
            }

            await LoadAppPoolsAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Action error: {ex.Message}";
        }
    }

    private static string GetStateCss(string? state) =>
        state?.ToLowerInvariant() switch
        {
            "started" => "state-pill state-started",
            "stopped" => "state-pill state-stopped",
            _ => "state-pill state-other"
        };
}